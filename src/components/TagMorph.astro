---
const tagline = "Claims. Verified.";
const brand = "Cvera";
---

<div class="tagmorph" data-tagmorph-root>
  <span class="tagmorph-sr">Cvera</span>

  <span class="tagmorph-line tagmorph-tagline" aria-hidden="true" data-tagline>
    {
      [...tagline].map((char, index) => {
        const isSpace = char === " ";
        const isPunctuation = char === ".";

        return (
          <span
            class:list={[
              "tagmorph-char",
              isSpace && "tagmorph-space",
              isPunctuation && "tagmorph-punctuation",
            ]}
            data-tag-char
            data-index={index}
            data-punctuation={isPunctuation ? "true" : "false"}
          >
            {isSpace ? "\u00A0" : char}
          </span>
        );
      })
    }
  </span>

  <span class="tagmorph-line tagmorph-brand" aria-hidden="true" data-brand>
    {
      [...brand].map((char, index) => (
        <span
          class:list={[
            "tagmorph-brand-char",
            index === 0 && "tagmorph-brand-char-first",
          ]}
          data-brand-char
          data-index={index}
        >
          {char}
        </span>
      ))
  }
  </span>
</div>

<style>
  .tagmorph {
    --tm-text: #111111;
    --tm-accent: #5b2a86;
    position: relative;
    display: inline-block;
    width: auto;
    max-width: 100%;
    height: 1.02em;
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif;
    font-size: clamp(3.5rem, 9vw, 7rem);
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--tm-text);
    text-rendering: optimizeLegibility;
    transform: translateX(0.02em);
  }

  .tagmorph-sr {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  .tagmorph-line {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: baseline;
    justify-content: center;
    white-space: nowrap;
  }

  .tagmorph-tagline {
    color: var(--tm-text);
    transform: translateX(-0.18em);
  }

  .tagmorph-brand {
    color: var(--tm-accent);
    transform: scale(1.06);
    transform-origin: center;
  }

  .tagmorph-char,
  .tagmorph-brand-char {
    display: inline-block;
    vertical-align: baseline;
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
    will-change: opacity, transform, filter;
  }

  .tagmorph-brand-char-first {
    margin-right: 0.035em;
  }

  .tagmorph-space {
    width: 0.26em;
  }

  .tagmorph-punctuation {
    color: var(--tm-accent);
  }
</style>

<script>
  import gsap from "gsap";

  const roots = document.querySelectorAll("[data-tagmorph-root]");

  roots.forEach((root) => {
    if (!(root instanceof HTMLElement)) return;

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const tagline = root.querySelector("[data-tagline]");
    const brand = root.querySelector("[data-brand]");

    if (!(tagline instanceof HTMLElement) || !(brand instanceof HTMLElement)) return;

    const tagChars = Array.from(root.querySelectorAll("[data-tag-char]")).filter(
      (el): el is HTMLElement => el instanceof HTMLElement
    );

    const punctuation = tagChars.filter((el) => el.dataset.punctuation === "true");

    const firstWord = tagChars.filter((el) => {
      const i = Number(el.dataset.index);
      return i >= 0 && i <= 5;
    });

    const secondWord = tagChars.filter((el) => {
      const i = Number(el.dataset.index);
      return i >= 8 && i <= 15;
    });

    const brandChars = Array.from(root.querySelectorAll("[data-brand-char]")).filter(
      (el): el is HTMLElement => el instanceof HTMLElement
    );

    gsap.killTweensOf([tagline, brand, ...tagChars, ...brandChars]);

    const resetState = () => {
      gsap.set(tagline, { opacity: 1, x: -14});
      gsap.set(tagChars, {
        opacity: 1,
        y: 0,
        x: 0,
        filter: "blur(0px)",
      });
      gsap.set(brand, { opacity: 1 });
      gsap.set(brandChars, {
        opacity: 0,
        y: 10,
        x: 0,
        scale: 1.06,
        filter: "blur(6px)",
      });
    };

    if (reduceMotion) {
      gsap.set(tagline, { opacity: 0 });
      gsap.set(brand, { opacity: 1, x: 0 });
      gsap.set(brandChars, { opacity: 1, y: 0, filter: "blur(0px)" });
      return;
    }

    resetState();

    const tl = gsap.timeline({
      repeat: -1,
      repeatDelay: 1.6,
      onRepeat: resetState,
    });

    tl.to({}, { duration: 1.3 })
      .to(
        firstWord,
        {
          opacity: 0,
          y: -6,
          filter: "blur(4px)",
          duration: 0.65,
          stagger: 0.07,
          ease: "power2.out",
        },
        0
      )
      .to(
        punctuation,
        {
          opacity: 0,
          duration: 0.38,
          stagger: 0.08,
          ease: "power1.out",
        },
        0.22
      )
      .to(
        secondWord,
        {
          opacity: 0,
          y: -6,
          filter: "blur(4px)",
          duration: 0.9,
          stagger: 0.045,
          ease: "power2.out",
        },
        0.42
      )
      .to(
        brandChars,
        {
          opacity: 1,
          y: 0,
          scale: 1.06,
          filter: "blur(0px)",
          duration: 0.9,
          stagger: 0.05,
          ease: "power2.out",
        },
        0.5
      )
      .to(
        tagline,
        {
          opacity: 0,
          duration: 0.32,
          ease: "power1.out",
        },
        0.95
      )
      .to({}, { duration: 1.2 });
  });
</script>