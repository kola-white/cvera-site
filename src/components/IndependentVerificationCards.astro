---
const verificationItems = [
  "signature validation",
  "trust chain evaluation",
  "revocation checking",
];
---

<div
  class="mt-4 grid max-w-3xl grid-cols-1 gap-3 sm:grid-cols-3"
  aria-label="Independent verification methods"
>
  {
    verificationItems.map((item) => (
      <div class="rounded-2xl border border-gray-200 bg-gray-50 px-4 py-4">
        <p class="text-sm leading-6 font-medium text-gray-900">{item}</p>
      </div>
    ))
  }
</div>