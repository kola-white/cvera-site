---
const verificationItems = [
  "Signature validation",
  "Trust chain evaluation",
  "Revocation checking",
];
---

<div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-3">
  <article class="rounded-2xl border border-gray-200 bg-gray-50 px-6 py-6">
    <h4 class="text-base font-semibold text-gray-900 md:text-lg">
      Issuance of a verifiable claim token
    </h4>
  </article>

  <article class="rounded-2xl border border-gray-200 bg-gray-50 px-6 py-6">
    <h4 class="text-base font-semibold text-gray-900 md:text-lg">
      User-held credential
    </h4>

    <p class="mt-2 text-sm leading-6 text-gray-600">
      Portable JSON held by the user.
    </p>
  </article>

  <article class="rounded-2xl border border-gray-200 bg-gray-50 px-6 py-6">
    <h4 class="text-base font-semibold text-gray-900 md:text-lg">
      Independent verification
    </h4>

    <ul class="mt-4 space-y-2" aria-label="Independent verification methods">
      {
        verificationItems.map((item) => (
          <li class="text-sm leading-6 text-gray-700">{item}</li>
        ))
      }
    </ul>
  </article>
</div>