<script type="module">
  import gsap from "gsap";

  const root = document.querySelector("[data-arch-diagram]");
  if (!root) return;

  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const groups = root.querySelectorAll("[data-arch-group]");
  const nodes = root.querySelectorAll("[data-arch-node]");
  const labels = root.querySelectorAll("[data-arch-label]");
  const edges = root.querySelectorAll("[data-arch-edge]");

  if (prefersReducedMotion) {
    gsap.set([...groups, ...nodes, ...labels, ...edges], {
      opacity: 1,
      clearProps: "all",
    });
  } else {
    edges.forEach((edge) => {
      const length = edge.getTotalLength();
      edge.style.strokeDasharray = `${length}`;
      edge.style.strokeDashoffset = `${length}`;
    });

    gsap.set(groups, { opacity: 0, y: 8 });
    gsap.set(nodes, { opacity: 0, y: 10 });
    gsap.set(labels, { opacity: 0, y: 4 });

    const animateDiagram = () => {
      const tl = gsap.timeline({ defaults: { ease: "power2.out" } });

      tl.to(groups, {
        opacity: 1,
        y: 0,
        duration: 0.42,
        stagger: 0.08,
      })
        .to(
          nodes,
          {
            opacity: 1,
            y: 0,
            duration: 0.38,
            stagger: 0.05,
          },
          "-=0.18",
        )
        .to(
          edges,
          {
            strokeDashoffset: 0,
            duration: 0.54,
            stagger: 0.05,
          },
          "-=0.14",
        )
        .to(
          labels,
          {
            opacity: 1,
            y: 0,
            duration: 0.26,
            stagger: 0.025,
          },
          "-=0.26",
        );
    };

    let hasPlayed = false;
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting && !hasPlayed) {
            hasPlayed = true;
            animateDiagram();
            observer.disconnect();
          }
        }
      },
      { threshold: 0.28 },
    );

    observer.observe(root);
  }
</script>

